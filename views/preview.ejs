<%- include('partials/header') %>

<section class="detail-section">
  <div class="detail-layout">

    <div class="detail-left">
      <div class="detail-art-wrap">
        <% if (song.artwork) { %>
          <img src="<%= song.artwork %>" alt="<%= song.title %>" class="detail-art" />
        <% } else { %>
          <div class="detail-art detail-art-ph">♪</div>
        <% } %>
        <% if (song.previewUrl) { %>
          <button class="btn-preview-big" data-preview="<%= song.previewUrl %>" data-title="<%= song.title %>">
            ▶ Preview
          </button>
        <% } %>
      </div>

      <% if (!existing) { %>
      <form action="/journal/add" method="POST" class="add-form">
        <input type="hidden" name="type"       value="song" />
        <input type="hidden" name="title"      value="<%= song.title %>" />
        <input type="hidden" name="artist"     value="<%= song.artist %>" />
        <input type="hidden" name="artwork"    value="<%= song.artwork %>" />
        <input type="hidden" name="genre"      value="<%= song.genre %>" />
        <input type="hidden" name="releaseYear" value="<%= song.releaseYear %>" />
        <input type="hidden" name="trackId"    value="<%= song.trackId %>" />
        <input type="hidden" name="albumName"  value="<%= song.album %>" />
        <input type="hidden" name="previewUrl" value="<%= song.previewUrl %>" />
        <input type="hidden" name="durationMs" value="<%= song.durationMs %>" />
        <input type="hidden" name="redirectTo" value="/search/preview/<%= song.trackId %>" />
        <button type="submit" class="btn btn-primary btn-block">+ Add to Journal</button>
      </form>
      <% } else { %>
        <a href="/journal/edit/<%= existing._id %>" class="btn btn-secondary btn-block">✏️ Edit Journal Entry</a>
        <p class="already-saved">✓ Already in your journal</p>
      <% } %>
    </div>

    <div class="detail-right">
      <div class="detail-type-badge">Song</div>
      <h1 class="detail-title"><%= song.title %></h1>
      <p class="detail-artist"><%= song.artist %></p>

      <div class="detail-chips">
        <% if (song.album) { %><span class="detail-chip">💿 <%= song.album %></span><% } %>
        <% if (song.releaseYear) { %><span class="detail-chip"><%= song.releaseYear %></span><% } %>
        <% if (song.genre) { %><span class="detail-chip"><%= song.genre %></span><% } %>
        <% if (song.duration) { %><span class="detail-chip">⏱ <%= song.duration %></span><% } %>
        <% if (song.trackNumber) { %><span class="detail-chip">Track <%= song.trackNumber %><% if (song.trackCount) { %>/<%= song.trackCount %><% } %></span><% } %>
      </div>

      <% if (mbArtistInfo) { %>
      <div class="mb-panel">
        <p class="mb-panel-title">About the Artist <span class="mb-credit">via MusicBrainz</span></p>
        <p class="mb-artist-name"><%= mbArtistInfo.name %></p>
        <% if (mbArtistInfo.disambiguation) { %><p class="mb-dis"><%= mbArtistInfo.disambiguation %></p><% } %>
        <div class="mb-chips">
          <% if (mbArtistInfo.type) { %><span class="meta-chip"><%= mbArtistInfo.type %></span><% } %>
          <% if (mbArtistInfo.country) { %><span class="meta-chip">📍 <%= mbArtistInfo.country %></span><% } %>
          <% if (mbArtistInfo.area) { %><span class="meta-chip">🏙 <%= mbArtistInfo.area %></span><% } %>
          <% if (mbArtistInfo.formed) { %><span class="meta-chip">Est. <%= mbArtistInfo.formed %></span><% } %>
          <% mbArtistInfo.tags.forEach(t => { %><span class="meta-chip tag-chip"><%= t %></span><% }) %>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <div class="player-bar" id="playerBar">
    <audio id="audioPlayer"></audio>
    <button class="player-play-btn" id="playerPlayBtn">▶</button>
    <div class="player-info"><span id="playerTitle">—</span></div>
    <div class="player-progress-wrap"><div class="player-progress" id="playerProgress"></div></div>
    <button class="player-close" id="playerClose">✕</button>
  </div>

  <div class="back-row">
    <a href="/search" class="btn btn-ghost">← Back to Search</a>
    <a href="/journal" class="btn btn-ghost">📓 My Journal</a>
  </div>
</section>

<%- include('partials/footer') %>
